# Copy to .env and fill in. Never commit .env.
POSTGRES_USER=apc
POSTGRES_PASSWORD=change-me
POSTGRES_DB=apc

# Long random string used to sign access tokens.
JWT_SIGNING_KEY=change-me-to-a-long-random-secret

API_PORT=8080

# Push credentials are mounted as files (see docker-compose.yml), not set here.
# APNS: place your .p8 key and set the path/team/key id in your deployment.
# FCM: place your service-account json.
